#include <stdio.h>
#include <stdlib.h>
#define MAX 100

int queue[MAX];
int front=-1,rear=-1;
void enqueue(int value){
    if(front==MAX-1){
        printf("Queue overflow\n");
        return;
    }
    if(front==-1){
        front=0;
    queue[++rear]=value;
    }
}
void dequeue(){
    if(front==-1 && front>=rear){
        printf("Queue underflow\n");
        return;
    }
    printf("Popped the element %d\n",queue[front++]);
}
int main(){
    int ch,value;
    scanf("%d",&ch);
    if(ch==1){
        scanf("%d",&value);
        enqueue(value);
    }
    else if(ch==2){
        dequeue();
    }
    return 0;
}
