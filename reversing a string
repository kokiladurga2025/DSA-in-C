#include <stdio.h>
#include <string.h>
#define MAX 100
char stack[MAX];
int top=-1;

void push(char ch){
    stack[++top]=ch;
    
}
char pop(){
    return stack[top--];
}
int main(){
    char input[200];
    scanf("%[^\n]",&input);
    int len=strlen(input);
    for(int i=0;i<len;i++){
        push(input[i]);
    }
    while(top!=-1){
        printf("%c",pop());
    }
    return 0;
}
